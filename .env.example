POSTGRES_USER=sopka
POSTGRES_PASSWORD=sopka
POSTGRES_DB=sopka
POSTGRES_PORT=5432

# Для контейнера api (hostname = db)
DATABASE_URL=postgresql+asyncpg://sopka:sopka@db:5432/sopka

# Локальный запуск uvicorn без Docker: localhost вместо db
# DATABASE_URL=postgresql+asyncpg://sopka:sopka@localhost:5432/sopka

API_PORT=8000

# Разрешённые источники CORS для браузера (через запятую). * — все origins.
CORS_ORIGINS=*
